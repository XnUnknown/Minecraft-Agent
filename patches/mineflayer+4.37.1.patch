+      // Paper (and other Spigot forks) send aggressive full inventory resyncs with
+      // windowId=0 after each window_click, which mineflayer applies to bot.inventory but
+      // NOT to this crafting-table window. The window's slots then go stale mid-craft and
+      // window.findInventoryItem() can't find an ingredient that bot.inventory still has,
+      // making bot.craft() throw a spurious 'missing ingredient'. Fall back to bot.inventory
+      // (which Paper keeps correct), remap the slot into window coordinates, and patch the
+      // window slot so subsequent clicks target the right place. No-op on vanilla, where the
+      // fast path already finds the item.
+      function findItemSynced (itemId, metadata) {
+        const fromWindow = window.findInventoryItem(itemId, metadata)
+        if (fromWindow) return fromWindow
+        const invItem = bot.inventory.findInventoryItem(itemId, metadata)
+        if (!invItem) return null
+        const slotOffset = window.inventoryStart - bot.inventory.inventoryStart
+        const windowSlot = invItem.slot + slotOffset
+        invItem.slot = windowSlot
+        window.updateSlot(windowSlot, invItem)
+        return invItem
+      }
+
