    "start:multi": "tsx scripts/launch-agents.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "gen:api-schema": "node scripts/gen-api-schema.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "mineflayer": "^4.23.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-tool": "^1.2.0",
    "openai": "^6.43.0",
    "prismarine-viewer": "^1.33.0",
    "vec3": "^0.1.10",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "nodemon": "^3.1.14",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
