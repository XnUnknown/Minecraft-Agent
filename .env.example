# LLM provider keys. Only the provider you select in config/providers.yaml needs a key.
# (Local Ollama needs none.) See README §4.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=

# If your server is online-mode (Microsoft auth), set server.auth: microsoft in
# config/default.yaml. Mineflayer will open a browser/device-code login on first run.
